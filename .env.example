# ── Required
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Models
HAIKU_MODEL=claude-haiku-4-5-20251001

# ── Server
PORT=8081

# ── Optional: LangSmith Tracing
# Enable automatic tracing and monitoring of all LLM calls.
# Sign up free at: https://smith.langchain.com/
# Get your API key from: https://smith.langchain.com/ → Settings → API Keys
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=langchain-evaluation-suite
